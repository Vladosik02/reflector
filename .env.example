# Который face-matching провайдер использовать.
# Возможные значения: mock (детерминированные мок-результаты).
# Когда появится реальный провайдер, добавится в enum в lib/env.ts.
FACE_MATCH_PROVIDER=mock

# Лимит запросов на минуту с одного IP для /api/match.
RATE_LIMIT_PER_MINUTE=10

# Публичный базовый URL сайта (используется в metadataBase, OG, sitemap).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---------- Phase 2.5: pay-per-search-unlock ----------

# Платёжный провайдер. mock — мгновенный успех в dev. stripe — реальный Checkout (нужен мерчант).
PAYMENT_PROVIDER=mock

# Цена unlock одной search-сессии в копейках. 29900 = 299 ₽.
UNLOCK_PRICE_MINOR=29900
UNLOCK_CURRENCY=rub

# Stripe (заполняется когда есть мерчант)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Подпись HttpOnly cookie с anonymous-сессией. Генерится `openssl rand -base64 32`.
SESSION_COOKIE_SECRET=replace-me-with-32-bytes-of-random-base64

# Подключение к Postgres (docker-compose поднимает локальный).
DATABASE_URL=postgresql://reflector:reflector_dev@localhost:5432/reflector?schema=public
