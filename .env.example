# Который face-matching провайдер использовать.
# Возможные значения: mock (детерминированные мок-результаты).
# Когда появится реальный провайдер, добавится в enum в lib/env.ts.
FACE_MATCH_PROVIDER=mock

# Лимит запросов на минуту с одного IP для /api/match.
RATE_LIMIT_PER_MINUTE=10

# Публичный базовый URL сайта (используется в metadataBase, OG, sitemap).
NEXT_PUBLIC_SITE_URL=http://localhost:3000
